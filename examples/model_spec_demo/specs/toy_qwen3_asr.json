{
  "schema_version": 1,
  "family": "toy_qwen3_asr",
  "display_name": "Toy Qwen3 ASR",
  "category": "asr",
  "status": "experimental",
  "tasks": ["asr"],
  "modes": ["offline"],
  "runtime": {
    "tags": ["server", "cuda", "vulkan", "cpu"],
    "default_format": "safetensors"
  },
  "capabilities": {
    "timestamps": true,
    "speaker_reference": false,
    "style_condition": false,
    "voice_design": false,
    "languages": ["auto", "en", "zh"]
  },
  "options": {
    "request": [
      {
        "name": "language",
        "type": "enum",
        "values": ["auto", "en", "zh"],
        "default": "auto",
        "description": "Recognition language."
      },
      {
        "name": "return_timestamps",
        "type": "bool",
        "default": false,
        "description": "Return token timestamps when supported."
      }
    ],
    "session": [
      {
        "name": "toy_qwen3_asr.lookahead",
        "type": "int",
        "default": 3,
        "description": "Toy decoder lookahead."
      }
    ],
    "load": [
      {
        "name": "toy_qwen3_asr.weight_type",
        "type": "enum",
        "values": ["native", "f32", "f16", "bf16", "q8_0"],
        "default": "native",
        "description": "Toy weight storage type."
      }
    ]
  },
  "packages": [
    {
      "id": "toy_qwen3_asr_local",
      "display_name": "Toy Qwen3 ASR Local Snapshot",
      "format": "safetensors",
      "precision": "native",
      "target_directory": "Toy-Qwen3-ASR",
      "required_files": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"],
      "layout": "safetensors",
      "source": {
        "kind": "local_snapshot",
        "path": "../toy_package",
        "include": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"]
      },
      "description": "Local toy package used by the model spec demo."
    }
  ],
  "layouts": {
    "safetensors": {
      "format": "safetensors",
      "roots": {
        "model": "."
      },
      "files": {
        "config": "model:config.json",
        "generation_config": "model:generation_config.json",
        "tokenizer_config": "model:tokenizer_config.json"
      },
      "optional_files": {
        "tokenizer_json": "model:tokenizer.json"
      },
      "tensors": {
        "weights": "model:model.safetensors"
      }
    }
  },
  "companions": [
    {
      "id": "toy_qwen3_forced_aligner",
      "kind": "model",
      "family": "qwen3_forced_aligner",
      "option": "toy_qwen3_asr.forced_aligner",
      "required": false,
      "required_for": ["timestamps"]
    },
    {
      "id": "toy_vad",
      "kind": "model",
      "family": "silero_vad",
      "option": "toy_qwen3_asr.vad",
      "required": false,
      "required_for": ["long_audio"]
    }
  ],
  "ui": {
    "recommended_package": "toy_qwen3_asr_local",
    "min_vram_gb": 1,
    "tags": ["ASR"],
    "docs": ["examples/model_spec_demo/README.md"],
    "summary": "Toy ASR package used to prove the model-spec subsystem shape."
  },
  "sources": [
    {
      "format": "safetensors",
      "roots": {
        "model": "."
      },
      "files": {
        "config": "model:config.json",
        "generation_config": "model:generation_config.json",
        "tokenizer_config": "model:tokenizer_config.json"
      },
      "optional_files": {
        "tokenizer_json": "model:tokenizer.json"
      },
      "tensors": {
        "weights": "model:model.safetensors"
      }
    }
  ]
}
